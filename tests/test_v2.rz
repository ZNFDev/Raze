// ── 12. The original hex() bug test ───────────────────────────
func hex_custom(int n) -> string {
    val hex_chars = "0123456789ABCDEF";
    var result = "";

    if (n == 0) { return "0x0"; }

    while (n > 0) {
        auto digit = n % 16;
        // ✅ FIXED: indexing now returns 1-char string, not ASCII int
        var ch = hex_chars[digit];
        result = ch + result;
        n = n / 16;
    }
    return "0x" + result;
}

func test_hex_bug() {
    println("\n=== 12. Original Hex Bug Fix ===");
    println("hex_custom(255)   = " + hex_custom(255));
    println("hex_custom(256)   = " + hex_custom(256));
    println("hex_custom(65535) = " + hex_custom(65535));
    println("hex_custom(0)     = " + hex_custom(0));
    // also the original code from the issue:
    println("hello" + " world");

    auto a = (int)69.0;
    println("(int)69.0 = " + str(a));

    for (int i = 0; i <= 5; i++) {
        println("hello " + str(i));
    }
}

// ── 13. Recursion + closures ──────────────────────────────────
func memoize(var fn) -> var {
    var cache = {};
    return func(int n) -> int {
        val key = str(n);
        if (cache.has(key)) { return cache[key]; }
        auto r = fn(n);
        cache[key] = r;
        return r;
    };
}

func fib_slow(int n) -> int {
    if (n <= 1) { return n; }
    return fib_slow(n-1) + fib_slow(n-2);
}

func test_advanced() {
    println("\n=== 13. Memoization + Advanced Closures ===");

    auto fib = memoize(func(int n) -> int { return fib_slow(n); });
    for (val i in range(0, 13)) {
        print(str(fib(i)) + " ");
    }
    println("");

    // Pipeline: compose a data processing chain
    var data = range(1, 11);
    auto result = data
        .filter(func(int n, int i) -> bool { return n % 2 != 0; })
        .map(func(int n, int i) -> int { return n * n; })
        .reduce(func(int acc, int n, int i) -> int { return acc + n; }, 0);
    println("sum of squares of odd [1..10] = " + str(result));
}

// ── 14. assert / error handling ───────────────────────────────
func test_assert() {
    println("\n=== 14. Assert ===");

    try {
        assert(1 + 1 == 2, "math is broken");
        println("assert(true): OK");
    } catch (e) { println("fail: " + str(e)); }

    try {
        assert(false, "intentional failure");
    } catch (e) { println("caught assert: " + str(e)); }
}

// ── 15. Struct ────────────────────────────────────────────────
struct Vec3 {
    float x;
    float y;
    float z;
}

func vec3_add(Vec3 a, Vec3 b) -> Vec3 {
    Vec3 r;
    r.x = a.x + b.x;
    r.y = a.y + b.y;
    r.z = a.z + b.z;
    return r;
}

func vec3_str(Vec3 v) -> string {
    return "(" + str(v.x) + ", " + str(v.y) + ", " + str(v.z) + ")";
}

func test_structs() {
    println("\n=== 15. Structs ===");
    Vec3 a; a.x=1.0; a.y=2.0; a.z=3.0;
    Vec3 b; b.x=4.0; b.y=5.0; b.z=6.0;
    auto c = vec3_add(a, b);
    println("a = " + vec3_str(a));
    println("b = " + vec3_str(b));
    println("a+b = " + vec3_str(c));
}

